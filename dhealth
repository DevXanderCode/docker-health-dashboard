#!/opt/homebrew/bin/bash
# remember to change this when deploying. to #!/usr/bin/env bash

set -euo pipefail
IFS=$'\n\t'

# Constants & Configuration
REFRESH_INTERVAL=5
WATCH_MODE=false
VERSION="1.0.0"
SCRIPT_NAME=$(basename $0)

# CPU/MEM thresholds for color coding
CPU_WARN=50  # % — green below, yellow above
CPU_CRIT=80  # % — red above
MEM_WARN=60  # % — green below, yellow above
MEM_CRIT=85  # % — red above
DISK_WARN=70 # % - green below, yellow above
DISK_CRIT=90 # % - red above

# ------------------------------------------------------------------------------
# COLORS & FORMATTING (degrade gracefully if terminal doesn't support them)
# ------------------------------------------------------------------------------
if tput colors &> /dev/null && (( $(tput colors) >= 8 )); then
    RESET=$(tput sgr0)
    BOLD=$(tput bold)
    DIM=$(tput dim)
    RED=$(tput setaf 1)
    GREEN=$(tput setaf 2)
    YELLOW=$(tput setaf 3)
    BLUE=$(tput setaf 4)
    MAGENTA=$(tput setaf 5)
    CYAN=$(tput setaf 6)
    WHITE=$(tput setaf 7)
else
    RESET=""BOLD=""DIM=""
    RED=""GREEN=""YELLOW=""BLUE=""CYAN=""WHITE=""
fi

# ------------------------------------------------------------------------------
# LOGGING HELPERS
# ------------------------------------------------------------------------------
log_info() { echo "${CYAN}[INFO] ${RESET}$*"; }
log_warn() { echo "${YELLOW}[WARN] ${RESET}$*" >&2;}
log_error() { echo "${RED}[ERROR] ${RESET}$*" >&2; }

# ------------------------------------------------------------------------------
# USAGE
# ------------------------------------------------------------------------------
usage() {
    cat <<EOF
${BOLD}${CYAN}Docker Health Dashboard${RESET} v${VERSION}
${BOLD}Usage:${RESET}
    ${SCRIPT_NAME} [OPTIONS]

${BOLD}OPTIONS:${RESET}
    -w              Enable live watch/auto-refresh mode
    -i <seconds>    Refresh interval in seconds (default: ${REFRESH_INTERVAL}s, requires -w)
    -h              Show this help message
    -v              Show version

${BOLD}COLOR THRESHOLDS:${RESET}
  CPU:  ${GREEN}< ${CPU_WARN}%${RESET} → OK   ${YELLOW}${CPU_WARN}-${CPU_CRIT}%${RESET} → WARN   ${RED}> ${CPU_CRIT}%${RESET} → CRITICAL
  MEM:  ${GREEN}< ${MEM_WARN}%${RESET} → OK   ${YELLOW}${MEM_WARN}-${MEM_CRIT}%${RESET} → WARN   ${RED}> ${MEM_CRIT}%${RESET} → CRITICAL

${BOLD}EXAMPLES:${RESET}
  ${SCRIPT_NAME}            # Snapshot once
  ${SCRIPT_NAME} -w         # Refresh every 5s
  ${SCRIPT_NAME} -w -i 10   # Refresh every 10s

EOF
}

while getopts ":wi:hv" opt; do
    case $opt in
        w) WATCH_MODE=true ;;
        i) REFRESH_INTERVAL="$OPTARG" ;;
        h) usage; exit 0;;
        v) log_info "v${VERSION}"; exit 0;;
        :) log_error "Option -${OPTARG} require an argument."; exit 1;;
        \?) log_error "Unknown option -${OPTARG}"; exit 1;;
    esac
done

if ! [[ "$REFRESH_INTERVAL" =~ ^[1-9]+$ ]] || (( "$REFRESH_INTERVAL" < 0 )); then
    echo "Interval must be a positive integer."
    exit 1;
fi

# ------------------------------------------------------------------------------
# DEPENDENCY CHECK
# ------------------------------------------------------------------------------
check_dependencies() {
    local missing=()

    for cmd in docker awk tput; do
        if ! command -v "$cmd" &>/dev/null; then
            missing+=("$cmd")
        fi
    done

    if (( "${#missing[@]}" > 0 )); then
        echo "Missing dependencies- ${missing[*]}";
        exit 1;
    fi

    if ! docker info &>/dev/null; then
        echo "Cannot connect to Docker daemon";
        exit 1;
    fi
}

# ------------------------------------------------------------------------------
# COLOR HELPERS
# ------------------------------------------------------------------------------

# Color a numeric metric against warn/crit thresholds
# Usage: colorize_metric <value_float> <warn> <crit>
colorize_metric() {
    local value="$1"
    local warn="$2"
    local crit="$3"

    # Strip % if present and compare as integers (floor)
    local numeric
    numeric=$(echo "$value" | awk '{ printf "%d\n", $1}')

    if (( "$numeric" > "$crit" )); then
        echo "${RED}${BOLD}${value}${RESET}"
    elif (( "$numeric" > "$warn" )); then
        echo "${YELLOW}${value}${RESET}"
    else
        echo "${GREEN}${value}${RESET}"
    fi
}

# Color Container Status
colorize_status() {
    local status="$1"

    case "${status,,}" in 
        running)            echo "${GREEN}${BOLD}● running${RESET}" ;;
        exited*|dead*)      echo "${RED}${BOLD}✖ ${status}${RESET}" ;;
        paused*)            echo "${YELLOW}⏸ ${status}${RESET}" ;;
        restarting*)        echo "${MAGENTA}↻ ${status}${RESET}" ;;
        unhealthy*)         echo "${RED}${BOLD}⚠ ${status}${RESET}" ;;
        healthy*)           echo "${GREEN}✔ ${status}${RESET}" ;;
        *)                  echo "${DIM}${status}${RESET}" ;;
    esac
}

# ------------------------------------------------------------------------------
# HEADER / FOOTER
# ------------------------------------------------------------------------------
print_header() {
    local term_width
    term_width=$(tput cols 2>/dev/null || 100)

    local timestamp
    timestamp=$(date "+%Y-%m-%d %H:%M:%S")

    local title=" 🐳 Docker Health Dashboard "
    local title_len=${#title}
    local padding=$(( (term_width - title_len) / 2 ))

    echo ""
    printf '%*s' "$padding" '' | tr ' ' '-'
    printf '%s' "${BOLD}${CYAN}${title}${RESET}"
    printf '%*s\n' "$padding" '' | tr ' ' '-'
    printf " ${DIM}Host:${RESET} ${WHITE}$(hostname)${RESET}   ${DIM}Time:${RESET}${WHITE}${timestamp}${RESET}"

    if $WATCH_MODE; then
        printf "   ${DIM}Refreshing every ${REFRESH_INTERVAL}s — Ctrl+C to exit${RESET}"
    fi

    echo -e "\n"
}

print_footer() {
    local total="$1"
    local running="$2"
    local stopped="$3"

    echo ""
    echo "        ${DIM}Total: ${WHITE}${total}${RESET}"
    echo "      ${GREEN}Running: ${running}${RESET}"
    echo "${RED}Stopped/Other: ${stopped}${RESET}"

    # System-level resource summary
    local mem_total mem_used mem_pct
    mem_total=$(free -m | awk '/^Mem:/ {print $2}')
    mem_used=$(free -m | awk '/^Mem:/{print $3}')
    # mem_pct=$(awk "BEGIN {printf \"%d\", ($mem_used/$mem_total)*100}")
    mem_pct=$(awk -v mem_used=$mem_used -v mem_total=$mem_total 'BEGIN {printf "%d", (mem_used/mem_total)*100}')

    local load_avg
    if [[ "$(uname)" == "Darwin" ]]; then
        load_avg=$(sysctl -n vm.loadavg | awk '{print $2, $3, $4}')
    else
        load_avg=$(awk '{print $1, $2, $3}' /proc/loadavg)
    fi

    local disk_pct
    disk_pct=$(df / | awk 'NR==2{gsub(/%/,"", $5); print $5}')

    echo ""
    printf "   ${DIM}Host Ram:${RESET} $(colorize_metric "${mem_pct}" "$MEM_WARN" "$MEM_CRIT") %% (${mem_used}MB / ${mem_total}MB)\n"
    printf "  ${DIM}Load Avg.:${RESET} ${WHITE}${load_avg}${RESET} (1m, 10m, 15m)\n"
    printf "  ${DIM}Root Disk:${RESET} $(colorize_metric "${disk_pct}" "$DISK_WARN" "$DISK_CRIT") %% used\n"
    echo ""
}

print_footer 12 34 543