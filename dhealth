#!/usr/bin/env bash

set -euo pipefail
IFS=$'\n\t'

# Constants & Configuration
REFRESH_INTERVAL=5
WATCH_MODE=false
VERSION="1.0.0"
SCRIPT_NAME=$(basename "$0")

# CPU/MEM thresholds for color coding
CPU_WARN=50  # % — green below, yellow above
CPU_CRIT=80  # % — red above
MEM_WARN=60  # % — green below, yellow above
MEM_CRIT=85  # % — red above
DISK_WARN=70 # % - green below, yellow above
DISK_CRIT=90 # % - red above

# ------------------------------------------------------------------------------
# COLORS & FORMATTING (degrade gracefully if terminal doesn't support them)
# ------------------------------------------------------------------------------
if tput colors &> /dev/null && (( $(tput colors) >= 8 )); then
    RESET=$(tput sgr0)
    BOLD=$(tput bold)
    DIM=$(tput dim)
    RED=$(tput setaf 1)
    GREEN=$(tput setaf 2)
    YELLOW=$(tput setaf 3)
    BLUE=$(tput setaf 4)
    MAGENTA=$(tput setaf 5)
    CYAN=$(tput setaf 6)
    WHITE=$(tput setaf 7)
else
    RESET="" BOLD="" DIM=""
    RED="" GREEN="" YELLOW="" BLUE="" MAGENTA="" CYAN="" WHITE=""
fi

# ------------------------------------------------------------------------------
# LOGGING HELPERS
# ------------------------------------------------------------------------------
log_info() { echo "${CYAN}[INFO] ${RESET}$*"; }
log_warn() { echo "${YELLOW}[WARN] ${RESET}$*" >&2;}
log_error() { echo "${RED}[ERROR] ${RESET}$*" >&2; }

# ------------------------------------------------------------------------------
# USAGE
# ------------------------------------------------------------------------------
usage() {
    cat <<EOF
${BOLD}${CYAN}Docker Health Dashboard${RESET} v${VERSION}
${BOLD}Usage:${RESET}
    ${SCRIPT_NAME} [OPTIONS]

${BOLD}OPTIONS:${RESET}
    -w              Enable live watch/auto-refresh mode
    -i <seconds>    Refresh interval in seconds (default: ${REFRESH_INTERVAL}s, requires -w)
    -h              Show this help message
    -v              Show version

${BOLD}COLOR THRESHOLDS:${RESET}
  CPU:  ${GREEN}< ${CPU_WARN}%${RESET} → OK   ${YELLOW}${CPU_WARN}-${CPU_CRIT}%${RESET} → WARN   ${RED}> ${CPU_CRIT}%${RESET} → CRITICAL
  MEM:  ${GREEN}< ${MEM_WARN}%${RESET} → OK   ${YELLOW}${MEM_WARN}-${MEM_CRIT}%${RESET} → WARN   ${RED}> ${MEM_CRIT}%${RESET} → CRITICAL

${BOLD}EXAMPLES:${RESET}
  ${SCRIPT_NAME}            # Snapshot once
  ${SCRIPT_NAME} -w         # Refresh every 5s
  ${SCRIPT_NAME} -w -i 10   # Refresh every 10s

EOF
}

# Return success (0) only for a positive integer with no leading zero: 1, 5, 10, 20…
# Kept as its own function so it is trivially unit-testable in isolation.
validate_interval() {
    [[ "$1" =~ ^[1-9][0-9]*$ ]]
}

# Parse command-line options into the global config vars. Lives in a function
# (instead of running at the top level) so the script can be sourced by tests
# without consuming or reacting to the test runner's own arguments.
parse_args() {
    while getopts ":wi:hv" opt; do
        case $opt in
            w) WATCH_MODE=true ;;
            i) REFRESH_INTERVAL="$OPTARG" ;;
            h) usage; exit 0 ;;
            v) log_info "v${VERSION}"; exit 0 ;;
            :) log_error "Option -${OPTARG} requires an argument."; exit 1 ;;
            \?) log_error "Unknown option -${OPTARG}"; exit 1 ;;
        esac
    done

    if ! validate_interval "$REFRESH_INTERVAL"; then
        log_error "Interval must be a positive integer."
        exit 1
    fi
}

# ------------------------------------------------------------------------------
# DEPENDENCY CHECK
# ------------------------------------------------------------------------------
check_dependencies() {
    local missing=()

    for cmd in docker awk tput; do
        if ! command -v "$cmd" &>/dev/null; then
            missing+=("$cmd")
        fi
    done

    if (( "${#missing[@]}" > 0 )); then
        echo "Missing dependencies- ${missing[*]}";
        exit 1;
    fi

    if ! docker info &>/dev/null; then
        echo "Cannot connect to Docker daemon";
        exit 1;
    fi
}

# ------------------------------------------------------------------------------
# COLOR HELPERS
# ------------------------------------------------------------------------------

# Color a numeric metric against warn/crit thresholds
# Usage: colorize_metric <value_float> <warn> <crit>
colorize_metric() {
    local value="$1"
    local warn="$2"
    local crit="$3"

    # Strip % if present and compare as integers (floor)
    local numeric
    numeric=$(echo "$value" | awk '{ printf "%d\n", $1}')

    if (( "$numeric" > "$crit" )); then
        echo "${RED}${BOLD}${value}${RESET}"
    elif (( "$numeric" > "$warn" )); then
        echo "${YELLOW}${value}${RESET}"
    else
        echo "${GREEN}${value}${RESET}"
    fi
}

# Color Container Status
colorize_status() {
    local status="$1"

    # Docker's status text is like "Up 12 days (unhealthy)", so we match the
    # health suffix as a *substring* (*unhealthy* / *healthy*) rather than a
    # prefix. Order matters: "unhealthy" must be tested before "healthy"
    # (which is a substring of it), and both before the generic up*/running
    # match, since a healthy/unhealthy status also contains "up".
    case "${status,,}" in
        *unhealthy*)        echo "${RED}${BOLD}⚠ ${status}${RESET}" ;;
        *healthy*)          echo "${GREEN}✔ ${status}${RESET}" ;;
        exited*|dead*)      echo "${RED}${BOLD}✖ ${status}${RESET}" ;;
        *paused*)           echo "${YELLOW}⏸ ${status}${RESET}" ;;
        restarting*)        echo "${MAGENTA}↻ ${status}${RESET}" ;;
        running|up*)        echo "${GREEN}${BOLD}● ${status}${RESET}" ;;
        *)                  echo "${DIM}${status}${RESET}" ;;
    esac
}

# Extract the human-readable uptime out of a docker status string.
#   "Up 3 hours"             -> "3 hours"
#   "Up 12 days (unhealthy)" -> "12 days"   (health suffix stripped)
#   "Exited (0) 2 days ago"  -> "-"         (not running)
# Pure function: input in $1, result on stdout. Easy to unit-test.
extract_uptime() {
    local status="$1"
    if [[ "$status" =~ ^Up\ (.+)$ ]]; then
        local up="${BASH_REMATCH[1]}"
        # Strip a trailing health-check suffix like " (healthy)" / " (unhealthy)".
        printf '%s\n' "${up% (*)}"
    else
        printf '%s\n' "-"
    fi
}

# ------------------------------------------------------------------------------
# HEADER / FOOTER
# ------------------------------------------------------------------------------
print_header() {
    local term_width
    term_width=$(tput cols 2>/dev/null || echo 100)

    local timestamp
    timestamp=$(date "+%Y-%m-%d %H:%M:%S")

    local title=" 🐳 Docker Health Dashboard "
    local title_len=${#title}
    local padding=$(( (term_width - title_len) / 2 ))

    echo ""
    printf '%*s' "$padding" '' | tr ' ' '-'
    printf '%s' "${BOLD}${CYAN}${title}${RESET}"
    printf '%*s\n' "$padding" '' | tr ' ' '-'
    printf " ${DIM}Host:${RESET} ${WHITE}$(hostname)${RESET}   ${DIM}Time:${RESET}${WHITE}${timestamp}${RESET}"

    if $WATCH_MODE; then
        printf "   ${DIM}Refreshing every ${REFRESH_INTERVAL}s — Ctrl+C to exit${RESET}"
    fi

    echo -e "\n"
}

print_footer() {
    local total="$1"
    local running="$2"
    local stopped="$3"

    echo ""
    echo "        ${DIM}Total: ${WHITE}${total}${RESET}"
    echo "      ${GREEN}Running: ${running}${RESET}"
    echo "${RED}Stopped/Other: ${stopped}${RESET}"

    # System-level resource summary
    local mem_total mem_used mem_pct
    mem_total=$(free -m | awk '/^Mem:/ {print $2}')
    mem_used=$(free -m | awk '/^Mem:/{print $3}')
    # mem_pct=$(awk "BEGIN {printf \"%d\", ($mem_used/$mem_total)*100}")
    mem_pct=$(awk -v mem_used="$mem_used" -v mem_total="$mem_total" 'BEGIN {printf "%d", (mem_used/mem_total)*100}')

    local load_avg
    if [[ "$(uname)" == "Darwin" ]]; then
        load_avg=$(sysctl -n vm.loadavg | awk '{print $2, $3, $4}')
    else
        load_avg=$(awk '{print $1, $2, $3}' /proc/loadavg)
    fi

    local disk_pct
    disk_pct=$(df / | awk 'NR==2{gsub(/%/,"", $5); print $5}')

    echo ""
    printf "   ${DIM}Host Ram:${RESET} $(colorize_metric "${mem_pct}" "$MEM_WARN" "$MEM_CRIT") %% (${mem_used}MB / ${mem_total}MB)\n"
    printf "  ${DIM}Load Avg.:${RESET} ${WHITE}${load_avg}${RESET} (1m, 10m, 15m)\n"
    printf "  ${DIM}Root Disk:${RESET} $(colorize_metric "${disk_pct}" "$DISK_WARN" "$DISK_CRIT") %% used\n"
    echo ""
}

# ------------------------------------------------------------------------------
# TABLE RENDERER
# ------------------------------------------------------------------------------
print_table() {
    # Column Widths
    local W_NAME=22
    local W_STATUS=18
    local W_CPU=10
    local W_MEM=22
    local W_MEM_PCT=10
    local W_NET=22
    local W_BLK=22
    local W_UPTIME=20

    # Header row
    printf "${BOLD}${BLUE}"
    printf "  %-${W_NAME}s %-${W_STATUS}s %${W_CPU}s %-${W_MEM}s %${W_MEM_PCT}s %-${W_NET}s %-${W_BLK}s %-${W_UPTIME}s\n" \
    "CONTAINER" "STATUS" "CPU %" "MEM USAGE / LIMIT" "MEM %" "NET I/O" "BLOCK I/O" "UPTIME"
    printf "${RESET}"

    # Separator
    local total_w=$((W_NAME + W_STATUS + W_CPU + W_MEM + W_MEM_PCT + W_NET + W_BLK + W_UPTIME + 14))
    printf "  "
    printf "%*s" "$total_w" "" | tr " " "-"
    echo ""

    # ------------------------------------------------------------------------------
    # Collect all container IDs + names + statuses (including stopped containers)
    # ------------------------------------------------------------------------------

    local all_containers
    all_containers=$(docker ps -a --format "{{.ID}}|{{.Names}}|{{.Status}}") || {
        log_error "Failed to list containers."
        return 1;
    }

    if [[ -z "$all_containers" ]]; then
        echo ""
        printf "  ${DIM}No containers found.${RESET}"
        echo ""
        return 0
    fi

    # ------------------------------------------------------------------------------
    # Collect docker stats for running containers (non-blocking, single snapshot)
    # ------------------------------------------------------------------------------
    local stats_output
    stats_output=$(docker stats --no-stream --format \
        "{{.ID}}|{{.CPUPerc}}|{{.MemUsage}}|{{.MemPerc}}|{{.NetIO}}|{{.BlockIO}}" \
        2>/dev/null) || true

    # Build a look up: container_short_id -> stats
    declare -A stats_map
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue;
        local sid
        sid=$(echo "$line" | cut -d"|" -f1)
        stats_map["$sid"]="$line"
    done <<< "$stats_output"

    # ------------------------------------------------------------------------------
    # Counters
    # ------------------------------------------------------------------------------
    local total=0 running_count=0 stopped_count=0

    # ------------------------------------------------------------------------------
    # Render each container row
    # ------------------------------------------------------------------------------
    while IFS="|" read -r cid cname cstatus; do
        [[ -z "$cid" ]] && continue
        total=$(( total + 1))

        local short_id="${cid:0:12}"

        # Truncate name if too long
        local display_name="${cname}"
        if (( ${#display_name} > $(( W_NAME - 2)) )); then
            display_name="${display_name:0:$((W_NAME - 8))}...${display_name:$((${#display_name} - 5))}"
        fi

        # Colorize Status
        local colored_status
        colored_status=$(colorize_status "$cstatus")

        # Counting Running vs stopped
        if [[ "${cstatus,,}" == *"up"* ]]; then
            running_count=$((running_count + 1))
        else
            stopped_count=$((stopped_count + 1))
        fi

        # Extract uptime from the status field, e.g. "Up 3 hours (healthy)" -> "3 hours"
        local uptime_display
        uptime_display=$(extract_uptime "$cstatus")
        if (( ${#uptime_display} > $(( W_UPTIME - 2 )) )); then
            uptime_display="${uptime_display:0:$((W_UPTIME - 3))}..."
        fi

        # Pull stats if available for this container.
        local cpu_pct="-" mem_usage="-" mem_pct="-" net_io="-" blk_io="-"
        local colored_cpu="${DIM}-${RESET}"
        local colored_mem="${DIM}-${RESET}"

        local stat_line="${stats_map[$short_id]:-}"
        if [[ -n "$stat_line" ]]; then
            cpu_pct=$(echo "$stat_line" | cut -d"|" -f2 | tr -d "%")
            mem_usage=$(echo "$stat_line" | cut -d"|" -f3)
            mem_pct=$(echo "$stat_line" | cut -d"|" -f4 | tr -d "%")
            net_io=$(echo "$stat_line" | cut -d"|" -f5)
            blk_io=$(echo "$stat_line" | cut -d"|" -f6)

            colored_cpu=$(colorize_metric "$cpu_pct" "$CPU_WARN" "$CPU_CRIT")
            colored_mem=$(colorize_metric "$mem_pct" "$MEM_WARN" "$MEM_CRIT")

            # Round to 1 decimal place for display
            cpu_pct=$(printf "%.1f%%" "$cpu_pct" 2>"/dev/null" || echo "${cpu_pct}%")
            mem_pct=$(printf "%.1f%%" "$mem_pct" 2>"/dev/null" || echo "${mem_pct}%")
        fi

        # Truncate long mem/net/blk strings
        local short_mem="${mem_usage:0:$((W_MEM - 2))}"
        local short_net="${net_io:0:$((W_NET - 2))}"
        local short_blk="${blk_io:0:$((W_BLK - 2))}"

        # Print row - use printf widths for non-colored fields
        # manually pad colored fields (color codes inflates string length)

        printf "  %-${W_NAME}s" "$display_name"

        # Status (colored - pad manually)
        printf "%s" "$colored_status"
        local status_raw_len=${#cstatus}
        local status_pad=$(( W_STATUS - status_raw_len - 2 )) # -2 for icon and spacing
        (( status_pad > 0 )) && printf "%*s" "$status_pad" ""

        # CPU (right-aligned, colored)
        local cpu_raw_len=${#cpu_pct}
        local cpu_pad=$(( W_CPU - cpu_raw_len ))
        (( cpu_pad > 0 )) && printf "%*s" "$cpu_pad" ""
        printf "%s " "$colored_cpu"

        # Mem usage
        printf "%-${W_MEM}s" "$short_mem"

        # Mem % (colored)
        printf "%s" "$colored_mem"
        local mem_pct_len=${#mem_pct}
        local mem_pct_pad=$(( W_MEM_PCT - mem_pct_len))
        (( mem_pct_pad > 0 )) && printf "%*s" "$mem_pct_pad" ""

        # NET IO, BLOCK IO, Uptime
        printf " %-${W_NET}s %-${W_BLK}s %-${W_UPTIME}s\n" \
          "$short_net" "$short_blk" "$uptime_display"

    done <<< "$all_containers"

    # Return counters via global vars (subshell-safe alternative: temp file or echo)
    TOTAL_CONTAINERS=$total
    RUNNING_CONTAINERS=$running_count
    STOPPED_CONTAINERS=$stopped_count
}

# ------------------------------------------------------------------------------
# MAIN RENDER LOOP
# ------------------------------------------------------------------------------
render_dashboard() {
    # In watch mode, clear screen each cycle
    $WATCH_MODE && clear

    print_header

    # These globals are set inside print_table
    TOTAL_CONTAINERS=0
    RUNNING_CONTAINERS=0
    STOPPED_CONTAINERS=0

    print_table

    print_footer "$TOTAL_CONTAINERS" "$RUNNING_CONTAINERS" "$STOPPED_CONTAINERS"
}

# ------------------------------------------------------------------------------
# ENTRY POINT
# ------------------------------------------------------------------------------

main() {
    parse_args "$@"
    check_dependencies

    if "$WATCH_MODE"; then
        # Trap Ctrl+C for a clean exit message
        trap 'echo -e "\n${DIM}Dashboard stopped.${RESET}"; exit 0' INT TERM

        while true; do
            render_dashboard
            sleep "$REFRESH_INTERVAL"
        done
    else
        render_dashboard
    fi
}

# Only run the dashboard when this file is executed directly (./dhealth).
# When it is *sourced* (e.g. by the test suite) BASH_SOURCE[0] != $0, so main
# does NOT run — letting tests load and call individual functions in isolation.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi